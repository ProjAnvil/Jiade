{
  "_comment": "RabbitMQ definitions for the commerce topology. Declares the commerce.events topic exchange plus per-service queues, retry queues (TTL 2000ms, dead-letter back to commerce.events), and dead-letter queues. Bindings match the constants hardcoded in cmd/{order,payment,fulfillment,inventory}/main.go. The commerce user is also declared here with a sha256 hash (salt + password 'commerce') because RabbitMQ 4.x skips RABBITMQ_DEFAULT_USER creation when load_definitions is set. rabbit_version intentionally omitted: the compose image tag rabbitmq:4.0-management floats, so pinning a version here would drift from the running broker.",
  "vhosts": [
    {
      "name": "/"
    }
  ],
  "users": [
    {
      "name": "commerce",
      "password_hash": "c2FsdEfy9O+pHO8UNPtH85TDd7qKxyF4eP6ucccfJbTiyAGf",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": [
        "management"
      ]
    }
  ],
  "permissions": [
    {
      "user": "commerce",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "exchanges": [
    {
      "name": "commerce.events",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "commerce.events.dlx",
      "vhost": "/",
